{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "permissions": {
    "allow": [
      "mcp__github__get_file_contents",
      "mcp__github__pull_request_read",
      "mcp__github__issue_read",
      "mcp__github__list_issues",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:aws.amazon.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Skill(dev-standards:dev-standards)",
      "Skill(github:pr-respond)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.notification_type // \"unknown\"' | { read -r t; case \"$t\" in idle_prompt) msg='Claude Codeがユーザー＝サンの入力を待機している……';; permission_prompt) msg='Claude Codeが権限のユルシを求めている……';; elicitation_dialog) msg='Claude CodeがMCPの入力を求めている……';; *) exit 0;; esac; curl -s -d \"$msg\" ntfy.sh/korosuke613-claude-563d9d65 >/dev/null 2>&1 || true; }",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "git@korosuke613": true,
    "doc@korosuke613": true,
    "engineer@korosuke613": true,
    "security@korosuke613": true,
    "github@korosuke613": true,
    "dev-standards@korosuke613": true,
    "claude-md-management@claude-plugins-official": true,
    "ept@cybozu-ept": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "language": "Japanese",
  "plansDirectory": "plans",
  "tui": "fullscreen",
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
